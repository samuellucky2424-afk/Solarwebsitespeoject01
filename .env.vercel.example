# Vercel project environment variables
# These go in Vercel Project Settings -> Environment Variables

# Backend variables served to the frontend at runtime via /api/config
# (NO "VITE_" prefix needed - they are NOT baked into the JS bundle)
SUPABASE_URL=https://xqvapaavywmqswtccfqu.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_FUNCTION_URL=https://xqvapaavywmqswtccfqu.functions.supabase.co
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_your_public_key_here

# Backend-only secrets used by the Vercel API routes
SUPABASE_SERVICE_ROLE_KEY=
APP_URL=https://greenlifesolarsolution.com
RESEND_API_KEY=
SUPPORT_EMAIL=YOUR_SUPPORT_CONTACT_ADDRESS
RESEND_FROM_EMAIL=YOUR_VERIFIED_SENDER_ADDRESS
ADMIN_EMAIL=YOUR_ADMIN_NOTIFICATION_ADDRESS

# Add Flutterwave backend secrets in Supabase Edge Functions, not in Vercel:
# FLUTTERWAVE_SECRET_KEY
# FLUTTERWAVE_WEBHOOK_SECRET_HASH
# FLUTTERWAVE_ENCRYPTION_KEY (optional for the current Standard Checkout flow)
